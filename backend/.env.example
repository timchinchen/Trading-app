# Copy this file to backend/.env and fill in your own values.
# backend/.env is gitignored - NEVER commit real credentials.

# Mode: "paper" (safe, no real money) or "live" (real orders)
APP_MODE=paper

# Alpaca paper credentials (required for paper mode)
ALPACA_PAPER_KEY=
ALPACA_PAPER_SECRET=

# Alpaca live credentials (required for live mode)
ALPACA_LIVE_KEY=
ALPACA_LIVE_SECRET=

# Market data: "ws" | "poll" | "mixed"
MARKET_DATA_MODE=mixed
POLL_INTERVAL_SECONDS=5

# Auth - generate a long random string, e.g. `openssl rand -hex 32`
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRE_MINUTES=1440

# Safety: manual-order fat-finger cap (separate from broker buying_power).
# Default is deliberately small so a misclick can't place a huge order.
# Editable at runtime from the Settings UI.
MANUAL_ORDER_MAX_NOTIONAL=100

# CORS
CORS_ORIGIN=http://localhost:5173


# ---- Agent (X/Twitter + Ollama) ----
AGENT_ENABLED=false
AGENT_AUTO_EXECUTE_LIVE=false           # in live mode, only propose by default

# Real-money sizing (tune to your seed capital).
AGENT_BUDGET_USD=200                    # total capital the agent manages
AGENT_WEEKLY_BUDGET_USD=200             # max new BUY notional per calendar week
AGENT_MIN_POSITION_USD=20               # floor for a single position
AGENT_MAX_POSITION_USD=40               # cap for a single position
AGENT_DAILY_LOSS_CAP_USD=20             # halt for the day if realised P/L <= -cap
AGENT_MAX_OPEN_POSITIONS=6              # ceiling on concurrent positions

# Cadence + fetch windows.
AGENT_CRON_MINUTES=30                   # every N minutes during market hours
AGENT_MAX_TWEETS_PER_ACCOUNT=20
AGENT_LOOKBACK_HOURS=24
AGENT_PER_ACCOUNT_TIMEOUT_S=45

# Signal thresholds (previously hard-coded in allocator.py - now tunable).
AGENT_MIN_SCORE=0.30                    # min signal score to size a trade
AGENT_MIN_CONFIDENCE=0.30               # min LLM confidence to size a trade
AGENT_TOP_N_CANDIDATES=5                # max candidates considered per run
AGENT_LLM_CONCURRENCY=3                 # max concurrent LLM calls

# Market-intel corroboration boost applied when a ticker shows up in both
# Twitter signals AND movers/news feeds.
AGENT_INTEL_BOOST=0.15

# Take-profit exit: sell a held position when it's up at least this fraction
# from the entry price (0.10 = +10%). Set to 0 to disable auto-sell.
AGENT_TAKE_PROFIT_PCT=0.10

# Avoid re-buying anything already bought within this window (hours). We are
# hunting for new ideas every run, not stacking the same ticker.
AGENT_RECENT_TRADE_WINDOW_HOURS=24

# ---- LLM provider ----
# "ollama" (local, free) or "openai" (hosted, requires OPENAI_API_KEY).
# This is just the default; you can switch + set keys live from Settings UI.
LLM_PROVIDER=ollama

# Ollama (local LLM)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# OpenAI (or any OpenAI-compatible endpoint, e.g. Azure / OpenRouter)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# ---- Deep Analysis LLM (advisor) ----
# Separate provider/model for the once-per-run portfolio advisor summary.
# When DEEP_LLM_ENABLED=false, the advisor reuses the Agent LLM above.
# Blank slots inherit from the Agent LLM (e.g. you can flip PROVIDER=openai
# and leave OPENAI_API_KEY blank to reuse the Agent one).
DEEP_LLM_ENABLED=false
DEEP_LLM_PROVIDER=openai
DEEP_LLM_OLLAMA_HOST=
DEEP_LLM_OLLAMA_MODEL=
DEEP_LLM_OPENAI_API_KEY=
DEEP_LLM_OPENAI_MODEL=gpt-4o-mini
DEEP_LLM_OPENAI_BASE_URL=

# ---- Per-ticker enrichment (optional but recommended) ----
# Financial Modeling Prep: fundamentals (quote, profile, ratios-ttm).
# Grab a free key at https://site.financialmodelingprep.com/register
# Free tier = 250 calls/day - more than enough for a 6-position book.
FMP_API_KEY=
FMP_BASE_URL=https://financialmodelingprep.com/api/v3

# SEC EDGAR requires a User-Agent that identifies you (name + email).
# No API key; free for low-volume use.
SEC_USER_AGENT=TradingApp (personal use) you@example.com

# Stocktwits is behind Cloudflare - we drive it via headless Chromium with
# your own logged-in session cookies. Leave empty to disable.
# Paste either:
#   (a) a JSON dict:   {"stocktwits_session":"...", "other":"..."}
#   (b) Netscape cookie.txt lines
# or set this via the Settings UI instead of committing to .env.
STOCKTWITS_COOKIES=

# twscrape (stores X account cookies in this sqlite db).
# After registering an X throwaway account via:
#   .venv/bin/python -m app.services.agent.setup add_cookies
# the agent uses those cookies to drive headless Chromium (Playwright).
TWSCRAPE_DB=./twscrape.db

# Comma-separated X handles (no @) - edit to your preferred accounts
TWITTER_ACCOUNTS=PeterLBrandt,LindaRaschke,MarkMinervini

# ---- Swing-trading skill (1-2 week horizon) ----
# Master toggle. When true the runner applies the setup detector + risk-based
# sizing to every watchlist symbol; when false it falls back to pure tweet
# sentiment allocation.
SWING_ENABLED=true

# Per-trade dollar risk as a fraction of AGENT_BUDGET_USD. 0.01 = 1%.
SWING_RISK_PER_TRADE_PCT=0.01

# Reject any setup whose reward/risk ratio is below this before sizing.
SWING_MIN_RR=2.0

# If a trade makes no progress within this many trading days, exit.
SWING_TIME_STOP_DAYS=5

# Move stop to breakeven once unrealised P/L hits this fraction (0.08 = +8%).
SWING_MOVE_STOP_BE_PCT=0.08

# Flag partial profit-take at this gain (advisor surfaces; no auto-sell).
SWING_PARTIAL_PCT=0.05

# Market regime filter: only BUY when this symbol is trending up (price
# above its MA with the MA rising).
SWING_MARKET_FILTER_SYMBOL=SPY
SWING_MARKET_FILTER_MA=50

# Bar history pulled per symbol for MA / RSI / swing-high-low detection.
SWING_BAR_LOOKBACK_DAYS=120

# ---- Auto-sell (max-hold window) ----
# Daily scan at 09:45 US/Eastern that closes any open position held longer
# than the cap. Paper: auto-executes. Live: proposes unless
# AGENT_AUTO_EXECUTE_LIVE is also true. Toggle from the Settings UI.
AUTO_SELL_ENABLED=true
AUTO_SELL_MAX_HOLD_DAYS=30
